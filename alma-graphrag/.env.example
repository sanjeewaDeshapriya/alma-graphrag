# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=alma_password123

# LLM provider for agents/embeddings: openai | gemini
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini
# Optional: override the OpenAI base URL (leave blank for default)
OPENAI_BASE_URL=

# Google Gemini (used when LLM_PROVIDER=gemini) — OpenAI-compatible endpoint.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Google Places
GOOGLE_MAPS_API_KEY=your-google-maps-key
GOOGLE_PLACES_BASE_URL=https://maps.googleapis.com/maps/api/place

# LiteAPI (hotel rates / content) — https://dashboard.liteapi.travel
LITEAPI_KEY=your-liteapi-key
LITEAPI_BASE_URL=https://api.liteapi.travel/v3.0
LITEAPI_ENABLED=false
LITEAPI_CURRENCY=LKR
LITEAPI_GUEST_NATIONALITY=LK
LITEAPI_CHECKIN_OFFSET_DAYS=14
LITEAPI_LOS_NIGHTS=1
LITEAPI_ADULTS=2
LITEAPI_MAX_RATES_PER_HOTEL=5
LITEAPI_TIMEOUT=10

# App defaults
DEFAULT_CITY=Piliyandala
DEFAULT_COUNTRY=Sri Lanka
DEFAULT_COUNTRY_CODE=LK
HOTEL_MAX_RESULTS=40
NEWS_MAX_ITEMS=30
HOTELS_CITIES=Piliyandala,Maharagama,Homagama
LLM_EXTRACT_ENABLED=false

# News API providers (free tier — set at least one for API-based news)
# Get your key: https://newsapi.org/register  (100 req/day free)
NEWS_API_KEY=
# Get your key: https://gnews.io/            (100 req/day free)
GNEWS_API_KEY=

# Redis cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# CRAG settings
CRAG_MIN_SCORE=0.6
CRAG_MAX_RETRIES=1

# Embeddings
EMBEDDING_MODEL=text-embedding-ada-002

# Neo4j vector index
HOTEL_VECTOR_INDEX=hotel_embeddings
