# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=alma_password123

# OpenAI
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini

# Google Places
GOOGLE_MAPS_API_KEY=your-google-maps-key
GOOGLE_PLACES_BASE_URL=https://maps.googleapis.com/maps/api/place

# App defaults
DEFAULT_CITY=Piliyandala
DEFAULT_COUNTRY=Sri Lanka
HOTEL_MAX_RESULTS=40
NEWS_MAX_ITEMS=30
HOTELS_CITIES=Piliyandala,Maharagama,Homagama
LLM_EXTRACT_ENABLED=false

# Redis cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# CRAG settings
CRAG_MIN_SCORE=0.6
CRAG_MAX_RETRIES=1

# Embeddings
EMBEDDING_MODEL=text-embedding-ada-002

# Neo4j vector index
HOTEL_VECTOR_INDEX=hotel_embeddings
